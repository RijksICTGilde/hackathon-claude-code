PROJECTS_DIR=./projects

# Authenticatie (optioneel, kan ook in de container via claude login)
# ANTHROPIC_API_KEY is alleen voor het API-plan (pay-per-use via console.anthropic.com)
# Bij een Max-abonnement gebruik je claude login in de container
# Voor GitHub: authenticeer binnen de container via `gh auth login` (token blijft
# bewaard in het claude-home volume — zie README)
ANTHROPIC_API_KEY=

# Optionele componenten (build-time toggles).
# Elke waarde moet exact 'true' of 'false' zijn (andere waardes laten de build falen).
# Verplicht bij gebruik van docker compose (compose.yml dwingt dit af via :?);
# bij een directe `docker build` gelden de Dockerfile-defaults (allemaal 'true').
# Geen spaties rond het '=' teken.

# SDKman voor JVM-talen (Java, Kotlin). Vereist ook voor de LSP-plugins
# (samen met INSTALL_ANTHROPIC_PLUGINS=true).
INSTALL_JVM=true

# rtk (reduce token use) + auto-patch.
INSTALL_RTK=true

# Developer Overheid NL plugins (standaarden, developer-overheid, nerds,
# internet). De geo- en zad-actions-plugins staan los achter eigen toggles
# omdat hun skill-bundels relatief veel context-budget kosten.
INSTALL_OVERHEID_PLUGINS=true

# Losse geo-plugin (Geonovum geo-standaarden). Standaard uit om context-budget
# te sparen; zet op true als je actief met geo-standaarden werkt.
INSTALL_OVERHEID_GEO=false

# Losse zad-actions-plugin (GitHub Actions voor Nederlandse overheid). Standaard
# uit om context-budget te sparen; zet op true als je ZAD-workflows ontwikkelt.
INSTALL_OVERHEID_ZAD_ACTIONS=false

# Anthropic plugins (github, pr-review-toolkit, commit-commands, superpowers,
# feature-dev, claude-md-management, code-review, code-simplifier,
# security-guidance, claude-code-setup, ralph-loop). LSP-plugins komen er
# ook bij als INSTALL_JVM=true.
INSTALL_ANTHROPIC_PLUGINS=true

# Lokale skills uit de skills/ directory (digital-waste-spotter).
INSTALL_LOCAL_SKILLS=true

# caveman plugin (third-party, https://github.com/JuliusBrussee/caveman):
# ultra-compressed communicatie-modus, snijdt ~75% tokens.
INSTALL_CAVEMAN=true

# Rootless Podman in de container: Maven+Testcontainers nested draaien zonder de
# host-agent-bridge (issue #44). Default false. Bij true ook de runtime-override
# nodig (compose.override.podman.yml.example) voor seccomp/apparmor + netwerk.
INSTALL_PODMAN=false

# Storage-driver voor rootless podman:
#   vfs     — veilig, default, geen /dev/fuse nodig. Trager/schijf-intensiever.
#   overlay — fuse-overlayfs: sneller, maar vereist /dev/fuse (groter kernel-
#             aanvaloppervlak, FUSE-CVE's). Zet dan óók PODMAN_FUSE_DEVICE=/dev/fuse.
# Wisselen van driver vereist eenmalig `podman system reset` in de container.
PODMAN_STORAGE_DRIVER=vfs
# Device dat aan de container wordt gegeven. /dev/null = no-op (vfs). Zet op
# /dev/fuse alleen samen met PODMAN_STORAGE_DRIVER=overlay.
PODMAN_FUSE_DEVICE=/dev/null

OPEN_HTTPS=true
# Alleen nodig als OPEN_HTTPS niet true is
ALLOWED_DOMAINS=developer.overheid.nl,internet.nl,geonovum.nl,logius.nl,standaarden.overheid.nl

# Verversen van geïnstalleerde marketplaces bij elke container-start, zodat
# plugin-bundels up-to-date blijven zonder image-rebuild. Niet-fataal: bij
# netwerk-/upstream-failure waarschuwt de container en draait door.
MARKETPLACE_AUTOUPDATE=true
